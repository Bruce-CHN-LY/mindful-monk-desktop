[
  {"id":"agama_001","text":"當觀色無常。如是觀者，則為正觀。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第1經（節錄）","excerpt":true},
  {"id":"agama_002","text":"正觀者，則生厭離。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第1經（節錄）","excerpt":true},
  {"id":"agama_003","text":"厭離者，喜貪盡；喜貪盡者，心解脫。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第1經（節錄）","excerpt":true},
  {"id":"agama_004","text":"如觀無常，苦、空、非我亦復如是。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第1經（節錄）","excerpt":true},
  {"id":"agama_005","text":"於色正思惟，觀色無常，如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第2經（節錄）","excerpt":true},
  {"id":"agama_006","text":"於識正思惟，觀識無常。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第2經（節錄）","excerpt":true},
  {"id":"agama_007","text":"若知、若明、若離欲貪，心解脫者，則能越怖。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第4經（節錄）","excerpt":true},
  {"id":"agama_008","text":"受、想、行、識無常；無常即苦，苦即非我。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第9經（節錄）","excerpt":true},
  {"id":"agama_009","text":"非我者，亦非我所。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第9經（節錄）","excerpt":true},
  {"id":"agama_010","text":"無常者則是苦，苦者則非我。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第11經（節錄）","excerpt":true},
  {"id":"agama_011","text":"色無常，受、想、行、識無常。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第12經（節錄）","excerpt":true},
  {"id":"agama_012","text":"於色如實知，色集如實知，色滅如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第31經（節錄）","excerpt":true},
  {"id":"agama_013","text":"色無常、苦、變易法，是名色患。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_014","text":"受無常、苦、變易法，是名受患。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_015","text":"想無常、苦、變易法，是名想患。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_016","text":"行無常、苦、變易法，是名行患。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_017","text":"識無常、苦、變易法，是名識患。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_018","text":"於色調伏欲貪、斷欲貪、越欲貪，是名色離。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_019","text":"於受調伏欲貪、斷欲貪、越欲貪，是名受離。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_020","text":"於行調伏欲貪、斷欲貪、越欲貪，是名行離。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第41經（節錄）","excerpt":true},
  {"id":"agama_021","text":"八聖道：正見乃至正定。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第42經（節錄）","excerpt":true},
  {"id":"agama_022","text":"色集、色滅、色味、色患、色離，如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第44經（節錄）","excerpt":true},
  {"id":"agama_023","text":"受、想、行、識不樂，心得解脫。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第60經（節錄）","excerpt":true},
  {"id":"agama_024","text":"捨住，正念正智。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第60經（節錄）","excerpt":true},
  {"id":"agama_025","text":"受陰無常、苦、變易之法，乃至滅盡、涅槃。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第61經（節錄）","excerpt":true},
  {"id":"agama_026","text":"如實知此色、此色集、此色滅。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第67經（節錄）","excerpt":true},
  {"id":"agama_027","text":"當知有身，當斷有身集，當證有身滅。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第71經（節錄）","excerpt":true},
  {"id":"agama_028","text":"正見、正志、正語、正業、正命、正方便、正念、正定。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第71經（節錄）","excerpt":true},
  {"id":"agama_029","text":"觀察彼陰無常、磨滅、不堅固、變易法。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第80經（節錄）","excerpt":true},
  {"id":"agama_030","text":"心樂、清淨、解脫，是名為空。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第80經（節錄）","excerpt":true},
  {"id":"agama_031","text":"於空閑處樹下坐，善觀色無常、磨滅、離欲之法。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第80經（節錄）","excerpt":true},
  {"id":"agama_032","text":"苦聖諦如實知，集、滅、道聖諦如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第91經（節錄）","excerpt":true},
  {"id":"agama_033","text":"離貪恚癡心，正智善解脫。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第92經（節錄）","excerpt":true},
  {"id":"agama_034","text":"觀五受陰如病、如癰、如刺、如殺。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第110經（節錄）","excerpt":true},
  {"id":"agama_035","text":"觀五受陰無常、苦、空、非我。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第110經（節錄）","excerpt":true},
  {"id":"agama_036","text":"有身當知，有身集當斷，有身滅當證。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第123經（節錄）","excerpt":true},
  {"id":"agama_037","text":"觀察已，於色欲貪斷；色貪斷已，心善解脫。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第128經（節錄）","excerpt":true},
  {"id":"agama_038","text":"如是觀者，於苦、集、滅、道狐疑斷。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第134經（節錄）","excerpt":true},
  {"id":"agama_039","text":"正觀故生厭，生厭故離喜、離貪。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第186經（節錄）","excerpt":true},
  {"id":"agama_040","text":"離喜、貪故，我說心正解脫。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第186經（節錄）","excerpt":true},
  {"id":"agama_041","text":"於眼正思惟、觀察無常故，於眼欲貪斷。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第187經（節錄）","excerpt":true},
  {"id":"agama_042","text":"耳、鼻、舌、身、意，正思惟、觀察故，欲貪斷。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第187經（節錄）","excerpt":true},
  {"id":"agama_043","text":"於眼離欲，心解脫者，堪任正盡苦。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第190經（節錄）","excerpt":true},
  {"id":"agama_044","text":"於眼、色離欲，心解脫者，堪任越生老病死苦。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第191經（節錄）","excerpt":true},
  {"id":"agama_045","text":"離諸相，寂滅解脫。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第197經（節錄）","excerpt":true},
  {"id":"agama_046","text":"若苦、若樂、不苦不樂，彼亦無常。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第199經（節錄）","excerpt":true},
  {"id":"agama_047","text":"於所受，正觀無我。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第200經（節錄）","excerpt":true},
  {"id":"agama_048","text":"眼無常，眼無常如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第249經（節錄）","excerpt":true},
  {"id":"agama_049","text":"眼生滅法，眼生滅法如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第249經（節錄）","excerpt":true},
  {"id":"agama_050","text":"住身念處，於心解脫、慧解脫如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第253經（依上下文節錄）","excerpt":true},
  {"id":"agama_051","text":"五受陰法，為病、為癰、為刺、為殺、無常、苦、空、非我。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第257經（節錄）","excerpt":true},
  {"id":"agama_052","text":"如實正觀世間集者，則不生世間無見。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第260經（節錄）","excerpt":true},
  {"id":"agama_053","text":"如實正觀世間滅，則不生世間有見。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第260經（節錄）","excerpt":true},
  {"id":"agama_054","text":"多聞聖弟子如實知色、色集、色滅、色味、色患、色離。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第265經（節錄）","excerpt":true},
  {"id":"agama_055","text":"一切取滅、愛盡、無欲、寂滅、涅槃。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第291經（節錄）","excerpt":true},
  {"id":"agama_056","text":"當如實知眼所作、智所作、寂滅所作。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第302經（節錄）","excerpt":true},
  {"id":"agama_057","text":"貪欲恚害覺，退滅壞其心，長養眾苦聚。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第310經（節錄）","excerpt":true},
  {"id":"agama_058","text":"眼見色，不苦、不樂，捨心住正念正智。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第337經（節錄）","excerpt":true},
  {"id":"agama_059","text":"耳聲、鼻香、舌味、身觸、意法，捨心住正念正智。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第337經（節錄）","excerpt":true},
  {"id":"agama_060","text":"苦如實知，苦集、苦滅、苦滅道跡如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第342經（節錄）","excerpt":true},
  {"id":"agama_061","text":"老死法如實知，老死集、老死滅、老死滅道跡如實知。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第350經（節錄）","excerpt":true},
  {"id":"agama_062","text":"苦滅道跡聖諦已知，當修。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第377經（節錄）","excerpt":true},
  {"id":"agama_063","text":"一切諸苦，永滅盡無餘。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第390經（節錄）","excerpt":true},
  {"id":"agama_064","text":"如實知息苦之道跡。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第390經（節錄）","excerpt":true},
  {"id":"agama_065","text":"順知、順入，斷諸有流，盡諸生死。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第401經（節錄）","excerpt":true},
  {"id":"agama_066","text":"苦、苦集、苦滅、苦滅道跡，是名四聖諦。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第425經（節錄）","excerpt":true},
  {"id":"agama_067","text":"於四聖諦如實知者，是則黠慧。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第432經（節錄）","excerpt":true},
  {"id":"agama_068","text":"身身觀念，精勤方便，正智正念。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第621經（節錄）","excerpt":true},
  {"id":"agama_069","text":"受、心、法法觀念住，調伏世間貪憂。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第620經（節錄）","excerpt":true},
  {"id":"agama_070","text":"苦聖諦如實知，乃至道跡如實知，是名慧根。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第645經（節錄）","excerpt":true},
  {"id":"agama_071","text":"正智見真諦，此苦及苦因，離苦得寂滅。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第940經（節錄）","excerpt":true},
  {"id":"agama_072","text":"苦苦及苦集，超苦之寂滅；賢聖八正道，安隱趣涅槃。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第987經（節錄）","excerpt":true},
  {"id":"agama_073","text":"我此身無常、有為、心因緣生。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第1021經（節錄）","excerpt":true},
  {"id":"agama_074","text":"以慈心、悲心、哀愍心而為人說，是名清淨說法。","category":"compassion","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第1129經（節錄）","excerpt":true},
  {"id":"agama_075","text":"諦觀察諸行，苦空非有我；繫念正觀身，多修習厭離。","category":"mind","weight":1,"enabled":true,"source":"《雜阿含經》","reference":"T02n0099，第1207經（節錄）","excerpt":true},
  {"id":"diamond_001","text":"應云何住？云何降伏其心？","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_002","text":"應如是住，如是降伏其心。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_003","text":"實無眾生得滅度者。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_004","text":"若菩薩有我相、人相、眾生相、壽者相，即非菩薩。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_005","text":"菩薩於法，應無所住行於布施。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_006","text":"不住色布施，不住聲、香、味、觸、法布施。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_007","text":"菩薩應如是布施，不住於相。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_008","text":"若菩薩不住相布施，其福德不可思量。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_009","text":"凡所有相，皆是虛妄。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_010","text":"若見諸相非相，則見如來。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_011","text":"乃至一念生淨信。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_012","text":"不應取法，不應取非法。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_013","text":"法尚應捨，何況非法。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_014","text":"如來所說身相，即非身相。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_015","text":"應無所住而生其心。","category":"mind","weight":2,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_016","text":"若心有住，則為非住。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_017","text":"離一切諸相，則名諸佛。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_018","text":"信心清淨，則生實相。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_019","text":"實相者，則是非相。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_020","text":"過去心不可得，現在心不可得，未來心不可得。","category":"mind","weight":2,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_021","text":"若以色見我，以音聲求我，是人行邪道，不能見如來。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_022","text":"如來者，無所從來，亦無所去。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_023","text":"一合相者，則是不可說。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_024","text":"說法者，無法可說，是名說法。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_025","text":"所言一切法者，即非一切法，是故名一切法。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_026","text":"實無有法，名為菩薩。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_027","text":"若菩薩通達無我法者，如來說名真是菩薩。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_028","text":"如來者，即諸法如義。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_029","text":"一切賢聖，皆以無為法而有差別。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_030","text":"若來若去、若坐若臥，是人不解我所說義。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_031","text":"於一切法，應如是知，如是見，如是信解。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_032","text":"不生法相。","category":"mind","weight":1,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_033","text":"不取於相，如如不動。","category":"mind","weight":2,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_034","text":"一切有為法，如夢幻泡影，如露亦如電。","category":"mind","weight":2,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true},
  {"id":"diamond_035","text":"應作如是觀。","category":"mind","weight":2,"enabled":true,"source":"《金剛般若波羅蜜經》","reference":"T08n0235（節錄）","excerpt":true}
]
